    "name_en": "SAVI - Soil Adjusted Vegetation Index",
    "category": "vegetation",
    "requiredBands": ["NIR", "RED"],
    "formula": "((NIR - RED) / (NIR + RED + L)) * (1 + L), L = 0.5",
    "preferredSources": ["Sentinel-2", "Landsat 8/9", "GeoTIFF مرفوع"],
    "geeSupported": true,
    "browserSupported": true,
    "requiredInputs": ["studyArea", "dateRange", "rasterBands"],
    "outputType": "raster",
    "colorRamp": "vegetation",
    "interpretationTemplateId": "savi",
    "limitations": "مناسب للغطاء النباتي المتناثر، ويظل حساسا لاختيار قيمة L."
  },
