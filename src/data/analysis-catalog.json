  {
    "id": "ndvi",
    "name_ar": "NDVI - مؤشر الغطاء النباتي",
    "name_en": "NDVI - Normalized Difference Vegetation Index",
    "category": "vegetation",
    "requiredBands": ["NIR", "RED"],
    "formula": "(NIR - RED) / (NIR + RED)",
    "preferredSources": ["Sentinel-2", "Landsat 8/9", "GeoTIFF مرفوع"],
    "geeSupported": true,
    "browserSupported": true,
    "requiredInputs": ["studyArea", "dateRange", "rasterBands"],
    "outputType": "raster",
    "colorRamp": "vegetation",
    "interpretationTemplateId": "ndvi",
    "limitations": "داخل المتصفح يحتاج GeoTIFF متعدد الحزم أو بيانات عينة. عبر GEE يحتاج مصادقة ومشروع مفعل."
  },
  {
    "id": "evi",
    "name_ar": "EVI - مؤشر الغطاء النباتي المحسن",
    "name_en": "EVI - Enhanced Vegetation Index",
    "category": "vegetation",
    "requiredBands": ["NIR", "RED", "BLUE"],
    "formula": "2.5 * ((NIR - RED) / (NIR + 6 * RED - 7.5 * BLUE + 1))",
    "preferredSources": ["MODIS", "Sentinel-2", "Landsat 8/9"],
    "geeSupported": true,
    "browserSupported": true,
    "requiredInputs": ["studyArea", "dateRange", "rasterBands"],
    "outputType": "raster",
    "colorRamp": "vegetation",
    "interpretationTemplateId": "evi",
    "limitations": "يتأثر بجودة التصحيح الجوي ويحتاج الحزمة الزرقاء."
  },
  {
